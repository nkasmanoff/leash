# Hugging Face token (used by Modal image at deploy time AND by the harness
# if it needs to pull anything locally). Set as a Modal secret named
# `huggingface-secret` for deployments.
HF_TOKEN=

# URL of the deployed Leash /chat endpoint (output of `modal serve` or
# `modal deploy leash.py`). The harness CLI and sweep scripts default to this.
LEASH_URL=https://YOUR-MODAL-USERNAME--leash-leash-chat-dev.modal.run

# Default agent flags (overridable per-run via CLI). All booleans accept
# 1/true/yes/on or 0/false/no/off.
LEASH_CLAMP=false
LEASH_THINKING=true
LEASH_FAKE_TOOLS=false
